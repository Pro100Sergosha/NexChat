# Frontend build-time config (Vite). Copy to frontend/.env for host `npm run dev`;
# only VITE_-prefixed vars are exposed to the client. These Firebase Web values
# are public identifiers (not secrets) — the private FCM service-account key
# lives server-side in the notifications service.

# Firebase Web app config (Project settings → General → Your apps → Web)
VITE_FIREBASE_API_KEY=AIzaSyDtqMBea68TLGu66w-9anOuxbZVs0sHxfw
VITE_FIREBASE_AUTH_DOMAIN=nexchat-d575d.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=nexchat-d575d
VITE_FIREBASE_STORAGE_BUCKET=nexchat-d575d.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=1074629915005
VITE_FIREBASE_APP_ID=1:1074629915005:web:9618ddfcb8875c93921c14

# Web Push certificate public key (Project settings → Cloud Messaging → Web
# configuration → Web Push certificates). Required for getToken(); empty = push
# registration is skipped (SSE still works).
VITE_FIREBASE_VAPID_KEY=BEGq9arFAbHZ6ZSYrOB8PbZ7wbS5C-D8045CY9djLTYVaFLB6o9L7PvL-TEjvG87F66xrqVK_14HdGUnsCnLP5U
