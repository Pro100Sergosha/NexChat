# ── Postgres ──
POSTGRES_USER=nexchat
POSTGRES_PASSWORD=nexchat
POSTGRES_DB=auth

# ── Auth service ──
AUTH_DATABASE_URL=postgresql+asyncpg://nexchat:nexchat@postgres:5432/auth
REDIS_URL=redis://redis:6379/0
JWT_SECRET_KEY=change-me-in-production
# Auth publishes the verification + password-reset emails to the shared broker
# below (RABBITMQ_URL, defined in the Notifications section). Frontend routes the
# emailed links point at; the token rides as ?token=. Default to the gateway origin.
EMAIL_VERIFY_URL_BASE=http://localhost:5173/verify-email
EMAIL_RESET_URL_BASE=http://localhost:5173/reset-password

# ── Chat service ──
CHAT_DATABASE_URL=postgresql+asyncpg://nexchat:nexchat@postgres:5432/chat

# ── Notifications service ──
NOTIFICATIONS_DATABASE_URL=postgresql+asyncpg://nexchat:nexchat@postgres:5432/notifications
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/
# Trusted-producer secret gating POST /notifications. Empty = manual emit off.
NOTIFICATIONS_SERVICE_TOKEN=change-me-in-production
# Firebase creds are a gitignored FILE, not an env value. Drop it at
# backend/notifications/secrets/serviceAccountKey.json (compose mounts it).
# Empty file = offline push disabled (graceful no-op).
# SMTP for the email channel. Host/port/TLS default to Gmail (smtp.gmail.com:587,
# STARTTLS); only credentials + sender live here. Empty = email disabled (no-op).
# For Gmail use an App Password, not the account password.
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=

# ── Frontend: Firebase Web / FCM push ──
# Public identifiers (not secrets — they ship in the client bundle). The gateway
# passes these to the Vite dev server; only VITE_-prefixed vars reach the client.
# The private FCM service-account key stays server-side (notifications/secrets/).
VITE_FIREBASE_API_KEY=AIzaSyDtqMBea68TLGu66w-9anOuxbZVs0sHxfw
VITE_FIREBASE_AUTH_DOMAIN=nexchat-d575d.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=nexchat-d575d
VITE_FIREBASE_STORAGE_BUCKET=nexchat-d575d.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=1074629915005
VITE_FIREBASE_APP_ID=1:1074629915005:web:9618ddfcb8875c93921c14
# Web Push certificate PUBLIC key (Cloud Messaging → Web configuration).
VITE_FIREBASE_VAPID_KEY=BEGq9arFAbHZ6ZSYrOB8PbZ7wbS5C-D8045CY9djLTYVaFLB6o9L7PvL-TEjvG87F66xrqVK_14HdGUnsCnLP5U
