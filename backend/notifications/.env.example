DATABASE_URL=postgresql+asyncpg://nexchat:nexchat@localhost:5432/notifications
REDIS_URL=redis://localhost:6379/0
RABBITMQ_URL=amqp://guest:guest@localhost:5672/
JWT_SECRET_KEY=change-me-in-production
# Trusted-producer secret for POST /notifications. Empty = manual HTTP emit off.
SERVICE_TOKEN=change-me-in-production
# Path to the Firebase service-account JSON (gitignored). Empty = push disabled.
# Never put the JSON itself here — this file is committed. Drop the file at:
#   backend/notifications/secrets/serviceAccountKey.json
FCM_CREDENTIALS_FILE=./secrets/serviceAccountKey.json
